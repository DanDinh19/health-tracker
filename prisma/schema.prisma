// Prisma schema for Health Tracker
// See: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User linked to Supabase auth (id = auth.users.id). Stores Oura tokens.
model User {
  id                   String    @id // Supabase auth user id (uuid)
  ouraAccessToken      String?
  ouraRefreshToken     String?
  ouraTokenExpiresAt   DateTime?
  appleHealthApiKey    String?   @unique @map("apple_health_api_key")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  ouraData             OuraData[]
  meals                Meal[]

  @@map("users")
}

// Cached Oura ring data for offline/expired-token display
model OuraData {
  id       String   @id @default(cuid())
  userId   String
  type     String   // sleep, activity, readiness, sleep_score, spo2, stress, workout, heartrate, sleep_time
  day      String   // YYYY-MM-DD
  data     Json     // chart row (day + type-specific fields)
  syncedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, day])
  @@index([userId, type])
  @@map("oura_data")
}

// Temporary state for OAuth flow; links Oura callback to the user who initiated.
model OAuthState {
  id        String   @id @default(cuid())
  state     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("oauth_states")
}

// Granular sleep data for dashboard (synced from Oura or manual)
model SleepData {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  day             String    // YYYY-MM-DD
  sleepStages     Int[]     @default([]) @map("sleep_stages") // 1=Awake, 2=Light, 3=Deep, 4=REM, each = 5 min
  sleepScore      Int?      @map("sleep_score")
  totalSleepTime  Int?      @map("total_sleep_time") // seconds
  awakeTime       Int?      @map("awake_time") // seconds
  avgHr           Decimal?  @db.Decimal(5, 2) @map("avg_hr")
  bedtimeStart    DateTime? @map("bedtime_start")
  bedtimeEnd      DateTime? @map("bedtime_end")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@unique([userId, day])
  @@index([userId, day])
  @@map("sleep_data")
}

// Apple Health workouts (from Watch/iPhone)
model AppleHealthWorkout {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  activityType String    @map("activity_type") // Running, Walking, Cycling, etc.
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  duration     Int?      // seconds
  calories     Float?
  distance     Float?    // meters
  sourceName   String?   @map("source_name") // "Apple Watch", "iPhone"
  sourceId     String?   @map("source_id") // for dedup
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([userId, startDate])
  @@map("apple_health_workouts")
}

// Apple Health metrics (steps, heart rate, etc.)
model AppleHealthRecord {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  type       String   // HKQuantityTypeIdentifierStepCount, HKQuantityTypeIdentifierHeartRate, etc.
  value      Float
  unit       String?
  startDate  DateTime @map("start_date")
  endDate    DateTime? @map("end_date")
  sourceName String?  @map("source_name")
  sourceId   String?  @map("source_id") // for dedup
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, type, startDate])
  @@map("apple_health_records")
}

// Apple Health activity summaries (daily rings)
model AppleHealthActivitySummary {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  date            String   // YYYY-MM-DD
  activeEnergy    Float?   @map("active_energy") // kcal
  exerciseMinutes Int?     @map("exercise_minutes")
  standHours      Int?     @map("stand_hours")
  sourceId        String?  @map("source_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([userId, date])
  @@index([userId, date])
  @@map("apple_health_activity_summaries")
}

// Diet: meals and items (from photo AI or manual)
model Meal {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  timestamp     DateTime  @map("timestamp")
  mealType      String    @map("meal_type") // breakfast, lunch, dinner, snack
  photoUrl      String?   @map("photo_url")
  totalKcal     Float     @map("total_kcal")
  totalProteinG Float     @map("total_protein_g")
  totalCarbsG   Float     @map("total_carbs_g")
  totalFatG     Float     @map("total_fat_g")
  source        String    @default("photo") // photo, manual
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealItem[]

  @@index([userId, timestamp])
  @@map("meals")
}

model MealItem {
  id         String  @id @default(cuid())
  mealId     String  @map("meal_id")
  foodName   String  @map("food_name")
  foodRefId  String? @map("food_ref_id") // USDA or external DB id
  quantity   Float
  unit       String  // piece, cup, gram, oz, etc.
  kcal       Float
  proteinG   Float   @map("protein_g")
  carbsG     Float   @map("carbs_g")
  fatG       Float   @map("fat_g")
  confidence Float?  // 0-1 from AI
  portion    String? // e.g. "2 eggs", "1 slice"

  meal Meal @relation(fields: [mealId], references: [id], onDelete: Cascade)

  @@index([mealId])
  @@map("meal_items")
}

// One health entry per record (e.g. weight, steps, mood for a given day)
model HealthEntry {
  id          String   @id @default(cuid())
  userId      String   // Supabase auth user id
  type        String   // e.g. "weight", "steps", "mood", "sleep_hours"
  value       Float    // numeric value (kg, steps, 1-10 mood, hours)
  unit        String?  // e.g. "kg", "steps", "hours"
  recordedAt  DateTime @default(now())
  note        String?

  @@map("health_entries")
}
